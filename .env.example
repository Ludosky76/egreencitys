# EGREENCITY'S — Tokens reseaux sociaux
# Copier ce fichier vers .env puis remplir avec vos vraies valeurs.
# Le fichier .env est ignore par git (.gitignore) — NE JAMAIS LE COMMITER.

# ── Facebook Page Pro ─────────────────────────────────────────
# Obtenir : https://developers.facebook.com/tools/explorer
# Voir guide : _dossiers/social-api-setup-guide.md (section Facebook)
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_TOKEN=

# ── LinkedIn Company Page ─────────────────────────────────────
# Obtenir : https://www.linkedin.com/developers/apps
# Voir guide : _dossiers/social-api-setup-guide.md (section LinkedIn)
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_ORG_URN=urn:li:organization:
